generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {

  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  wallet    String?

  role      String   @default("PATIENT")

  cpf       String?  @unique  // pacientes
  crm       String?           // médicos
  cnpj      String?           // farmácias

  createdAt DateTime @default(now())

  prescriptions Prescription[]

}

model Prescription {

  id           String   @id
  ipfsHash     String
  patient      String
  patientEmail String?                    // email para notificação (RF06)
  medication   String
  dosage       String
  qr           String

  status     String   @default("ACTIVE") // ACTIVE | USED | REVOKED

  doctorId   String
  doctor     User     @relation(fields: [doctorId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

}